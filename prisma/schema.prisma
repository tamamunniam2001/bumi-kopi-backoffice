generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(CASHIER)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  dailyReports DailyReport[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id          String              @id @default(cuid())
  code        String?             @unique
  name        String
  price       Int
  stock       Int                 @default(0)
  imageUrl    String?
  isActive    Boolean             @default(true)
  categoryId  String?
  category    Category?           @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  ingredients ProductIngredient[]
  createdAt   DateTime            @default(now())

  @@index([isActive])
  @@index([categoryId])
}

model Ingredient {
  id       String              @id @default(cuid())
  code     String?             @unique
  name     String              @unique
  unit     String
  products ProductIngredient[]
}

model ProductIngredient {
  id           String     @id @default(cuid())
  qty          Float
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([productId, ingredientId])
}

model Transaction {
  id           String      @id @default(cuid())
  invoiceNo    String      @unique
  customerName String?     @default("")
  note         String?     @default("")
  total        Int
  payment      Int
  change       Int
  payMethod    PayMethod   @default(CASH)
  status       TxStatus    @default(COMPLETED)
  servedAt     DateTime?
  cashierId    String
  cashier      User        @relation(fields: [cashierId], references: [id])
  items        OrderItem[]
  createdAt    DateTime    @default(now())

  @@index([createdAt])
  @@index([cashierId])
  @@index([status, createdAt])
}

model OrderItem {
  id            String      @id @default(cuid())
  qty           Int
  price         Int
  subtotal      Int
  productId     String?
  product       Product?    @relation(fields: [productId], references: [id])
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

enum Role {
  ADMIN
  CASHIER
}

enum PayMethod {
  CASH
  QRIS
  TRANSFER
  NONTUNAI
}

enum TxStatus {
  COMPLETED
  CANCELLED
  PENDING
}

model DailyReport {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  kasAwal       Int      @default(0)
  penjualan     Int      @default(0)
  uangDisetor   Int      @default(0)
  qris          Int      @default(0)
  transfer      Int      @default(0)
  pengeluaran   Json     @default("[]")
  piutang       Json     @default("[]")
  catatan       String?  @default("")
  cashierId     String
  cashier       User     @relation(fields: [cashierId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([cashierId])
  @@index([date])
}

model Employee {
  id            String       @id @default(cuid())
  name          String
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  absences      Attendance[]
  helperOf      Attendance[] @relation("AttendanceHelper")
}

model SopItem {
  id        String   @id @default(cuid())
  text      String
  type      SopType
  order     Int      @default(0)
  isActive  Boolean  @default(true)
}

model Attendance {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  type         SopType
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  helperId     String?
  helper       Employee? @relation("AttendanceHelper", fields: [helperId], references: [id])
  kasAwal      Int      @default(0)
  checklist    Json     @default("[]")
  createdAt    DateTime @default(now())

  @@index([employeeId])
  @@index([date])
  @@index([type])
}

enum SopType {
  OPENING
  CLOSING
}
