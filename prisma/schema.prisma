generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(CASHIER)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  dailyReports DailyReport[]
  expenses     Expense[]
  stockOpnames StockOpname[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id          String              @id @default(cuid())
  code        String?             @unique
  name        String
  price       Int
  stock       Int                 @default(0)
  imageUrl    String?
  isActive    Boolean             @default(true)
  categoryId  String?
  category    Category?           @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  ingredients ProductIngredient[]
  createdAt   DateTime            @default(now())

  @@index([isActive])
  @@index([categoryId])
}

model Ingredient {
  id       String              @id @default(cuid())
  code     String?             @unique
  name     String              @unique
  unit     String
  products ProductIngredient[]
}

model ProductIngredient {
  id           String     @id @default(cuid())
  qty          Float
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([productId, ingredientId])
}

model Transaction {
  id           String      @id @default(cuid())
  invoiceNo    String      @unique
  customerName String?     @default("")
  note         String?     @default("")
  total        Int
  payment      Int
  change       Int
  payMethod    PayMethod   @default(CASH)
  status       TxStatus    @default(COMPLETED)
  servedAt     DateTime?
  cashierId    String
  cashier      User        @relation(fields: [cashierId], references: [id])
  items        OrderItem[]
  createdAt    DateTime    @default(now())

  @@index([createdAt])
  @@index([cashierId])
  @@index([status, createdAt])
}

model OrderItem {
  id            String      @id @default(cuid())
  qty           Int
  price         Int
  subtotal      Int
  productId     String?
  product       Product?    @relation(fields: [productId], references: [id])
  name          String?     @default("")
  code          String?     @default("")
  category      String?     @default("")
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

enum Role {
  ADMIN
  CASHIER
}

enum PayMethod {
  CASH
  QRIS
  TRANSFER
  NONTUNAI
}

enum TxStatus {
  COMPLETED
  CANCELLED
  PENDING
}

model DailyReport {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  kasAwal       Int      @default(0)
  penjualan     Int      @default(0)
  uangDisetor   Int      @default(0)
  qris          Int      @default(0)
  transfer      Int      @default(0)
  pengeluaran   Json     @default("[]")
  piutang       Json     @default("[]")
  catatan       String?  @default("")
  cashierId     String
  cashier       User     @relation(fields: [cashierId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([cashierId])
  @@index([date])
}

model Employee {
  id            String       @id @default(cuid())
  name          String
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  absences      Attendance[]
  helperOf      Attendance[] @relation("AttendanceHelper")
}

model SopItem {
  id        String   @id @default(cuid())
  text      String
  type      SopType
  order     Int      @default(0)
  isActive  Boolean  @default(true)
}

model ExpenseItem {
  id        String          @id @default(cuid())
  code      String?         @unique
  name      String
  category  String?         @default("")
  satuan    String?         @default("")
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  details   ExpenseDetail[]
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Expense {
  id        String        @id @default(cuid())
  date      DateTime      @default(now())
  total     Float
  catatan   String?       @default("")
  cashierId String
  cashier   User          @relation(fields: [cashierId], references: [id])
  items     ExpenseDetail[]
  createdAt DateTime      @default(now())

  @@index([cashierId])
  @@index([date])
}

model ExpenseDetail {
  id           String      @id @default(cuid())
  expenseId    String
  expense      Expense     @relation(fields: [expenseId], references: [id])
  expenseItemId String?
  expenseItem  ExpenseItem? @relation(fields: [expenseItemId], references: [id])
  name         String
  category     String?     @default("")
  keterangan   String?     @default("")
  satuan       String?     @default("")
  harga        Float
  qty          Float       @default(1)
  subtotal     Float

  @@index([expenseId])
}

model Attendance {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  type         SopType
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  helperId     String?
  helper       Employee? @relation("AttendanceHelper", fields: [helperId], references: [id])
  kasAwal      Int      @default(0)
  checklist    Json     @default("[]")
  createdAt    DateTime @default(now())

  @@index([employeeId])
  @@index([date])
  @@index([type])
}

enum SopType {
  OPENING
  CLOSING
}

model MonthlyKas {
  id        String   @id @default(cuid())
  year      Int
  month     Int      // 0-11
  kasAwal   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

model InventoryItem {
  id        String             @id @default(cuid())
  name      String
  qty       Float              @default(0)
  satuan    String?            @default("")
  category  String?            @default("")
  imageUrl  String?            @db.Text
  note      String?            @default("")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  opnameItems StockOpnameItem[]

  @@index([category])
}

model StockOpname {
  id        String            @id @default(cuid())
  date      DateTime          @default(now())
  note      String?           @default("")
  status    OpnameStatus      @default(DRAFT)
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  items     StockOpnameItem[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([date])
  @@index([userId])
}

model StockOpnameItem {
  id              String        @id @default(cuid())
  opnameId        String
  opname          StockOpname   @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  qtySystem       Float         @default(0)
  qtyActual       Float         @default(0)
  selisih         Float         @default(0)
  note            String?       @default("")

  @@index([opnameId])
  @@index([inventoryItemId])
}

enum OpnameStatus {
  DRAFT
  SELESAI
}
